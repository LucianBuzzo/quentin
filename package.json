{
	"name": "quentin",
	"version": "1.0.0",
	"description": "A tiny DOM helper for selection, class manipulation, and traversal.",
	"private": true,
	"type": "commonjs",
	"scripts": {
		"build": "tsc -p tsconfig.json && npm run build:min",
		"build:min": "terser quentin.js -c -m -o quentin.min.js",
		"typecheck": "tsc --noEmit",
		"test": "npm run build && jest --runInBand",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@commitlint/cli": "^19.8.0",
		"@commitlint/config-conventional": "^19.8.0",
		"husky": "^9.1.7",
		"jest": "^30.1.3",
		"jest-environment-jsdom": "^30.1.2",
		"terser": "^5.39.0",
		"typescript": "^5.9.2"
	},
	"license": "UNLICENSED"
}
