{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"release-type": "simple",
	"changelog-sections": [
		{
			"type": "feat",
			"section": "Features"
		},
		{
			"type": "fix",
			"section": "Bug Fixes"
		},
		{
			"type": "perf",
			"section": "Performance"
		},
		{
			"type": "refactor",
			"section": "Refactoring"
		},
		{
			"type": "docs",
			"section": "Documentation"
		},
		{
			"type": "test",
			"section": "Tests"
		},
		{
			"type": "chore",
			"section": "Chores",
			"hidden": true
		}
	],
	"packages": {
		".": {
			"release-type": "simple"
		}
	}
}
